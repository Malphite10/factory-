{
  "opportunity-report.json": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Opportunity Report (Creative Director)",
    "type": "object",
    "required": ["agent", "inputs", "outputs", "handoff", "blockers"],
    "properties": {
      "agent": { "const": "00-creative-director" },
      "version": { "type": "string" },
      "timestamp": { "type": "string", "format": "date-time" },
      "inputs": {
        "type": "object",
        "required": ["strategy", "timeline"],
        "properties": {
          "strategy": { "type": "string", "minLength": 1 },
          "timeline": { "type": "string", "enum": ["Q1", "Q2", "Q3", "Q4", "urgent"] },
          "budget": { "type": "number", "minimum": 0 }
        }
      },
      "tasks": { "type": "array", "items": { "type": "string" } },
      "outputs": {
        "type": "object",
        "required": ["brief", "target_audience", "success_criteria"],
        "properties": {
          "brief": { "type": "string", "minLength": 10 },
          "target_audience": { "type": "string" },
          "success_criteria": { "type": "array", "items": { "type": "string" } },
          "tone": { "type": "string" },
          "visual_direction": { "type": "string" }
        }
      },
      "handoff": {
        "type": "object",
        "required": ["next_agent"],
        "properties": {
          "next_agent": { "const": "01-research" },
          "required_approvals": { "type": "array" },
          "sla": { "type": "string" }
        }
      },
      "blockers": { "type": "array", "items": { "type": "string" } }
    }
  },

  "research-package.json": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Research Package (Research Agent)",
    "type": "object",
    "required": ["agent", "inputs", "outputs", "handoff", "blockers"],
    "properties": {
      "agent": { "const": "01-research" },
      "version": { "type": "string" },
      "timestamp": { "type": "string", "format": "date-time" },
      "inputs": {
        "type": "object",
        "required": ["upstream_package"],
        "properties": {
          "upstream_package": { "type": "object" },
          "upstream_agent": { "const": "00-creative-director" }
        }
      },
      "tasks": { "type": "array", "items": { "type": "string" } },
      "outputs": {
        "type": "object",
        "required": ["market_insights", "competitor_analysis", "template_recommendations"],
        "properties": {
          "market_insights": { "type": "string" },
          "competitor_analysis": { "type": "array", "items": { "type": "object" } },
          "template_recommendations": { "type": "array", "minItems": 1 },
          "recommended_platform": { "enum": ["Wix", "Salla", "custom"] }
        }
      },
      "handoff": {
        "type": "object",
        "required": ["next_agent"],
        "properties": {
          "next_agent": { "const": "02-product" },
          "confidence_score": { "type": "number", "minimum": 0, "maximum": 100 }
        }
      },
      "blockers": { "type": "array" }
    }
  },

  "product-spec.json": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Product Specification (Product Agent)",
    "type": "object",
    "required": ["agent", "inputs", "outputs", "handoff", "blockers"],
    "properties": {
      "agent": { "const": "02-product" },
      "version": { "type": "string" },
      "timestamp": { "type": "string", "format": "date-time" },
      "inputs": {
        "type": "object",
        "required": ["opportunity_report", "research_package"],
        "properties": {
          "opportunity_report": { "type": "object" },
          "research_package": { "type": "object" },
          "constraints": { "type": "array", "items": { "type": "string" } }
        }
      },
      "tasks": { "type": "array", "items": { "type": "string" } },
      "outputs": {
        "type": "object",
        "required": ["information_architecture", "user_flows", "feature_list", "cms_schema"],
        "properties": {
          "information_architecture": { "type": "object" },
          "user_flows": { "type": "array" },
          "feature_list": { "type": "array", "minItems": 1 },
          "cms_schema": { "type": "object" },
          "technical_constraints": { "type": "array" }
        }
      },
      "handoff": {
        "type": "object",
        "required": ["next_agent"],
        "properties": {
          "next_agent": { "const": "03-design" },
          "design_brief": { "type": "string" }
        }
      },
      "blockers": { "type": "array" }
    }
  },

  "design-package.json": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Design Package (Design Agent)",
    "type": "object",
    "required": ["agent", "inputs", "outputs", "handoff", "blockers"],
    "properties": {
      "agent": { "const": "03-design" },
      "version": { "type": "string" },
      "timestamp": { "type": "string", "format": "date-time" },
      "inputs": {
        "type": "object",
        "required": ["product_spec"],
        "properties": {
          "product_spec": { "type": "object" },
          "design_system_version": { "type": "string" }
        }
      },
      "tasks": { "type": "array", "items": { "type": "string" } },
      "outputs": {
        "type": "object",
        "required": ["figma_url", "design_tokens", "component_inventory", "responsive_breakpoints"],
        "properties": {
          "figma_url": { "type": "string", "format": "uri" },
          "design_tokens": { "type": "object" },
          "component_inventory": { "type": "array" },
          "responsive_breakpoints": { "type": "object" },
          "accessibility_notes": { "type": "string" }
        }
      },
      "handoff": {
        "type": "object",
        "required": ["next_agent"],
        "properties": {
          "next_agent": { "const": "05-github-supply-chain" },
          "design_system_compliance": { "type": "boolean" }
        }
      },
      "blockers": { "type": "array" }
    }
  },

  "github-package.json": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "GitHub Supply Chain Approval (GitHub Supply Chain Agent)",
    "type": "object",
    "required": ["agent", "inputs", "outputs", "handoff", "blockers"],
    "properties": {
      "agent": { "const": "05-github-supply-chain" },
      "version": { "type": "string" },
      "timestamp": { "type": "string", "format": "date-time" },
      "inputs": {
        "type": "object",
        "required": ["design_package", "dependencies_list"],
        "properties": {
          "design_package": { "type": "object" },
          "dependencies_list": { "type": "array" }
        }
      },
      "tasks": { "type": "array", "items": { "type": "string" } },
      "outputs": {
        "type": "object",
        "required": ["approved", "security_score", "maintenance_score", "recommended_versions", "integration_notes"],
        "properties": {
          "approved": { "type": "boolean" },
          "repository": { "type": "string" },
          "license": { "type": "string" },
          "security_score": { "type": "number", "minimum": 0, "maximum": 100 },
          "maintenance_score": { "type": "number", "minimum": 0, "maximum": 100 },
          "dependency_review": { "type": "array" },
          "license_compliance": { "type": "boolean" },
          "security_issues": { "type": "array" },
          "recommended_versions": { "type": "object" },
          "sbom": { "type": "object" },
          "integration_notes": { "type": "array", "minItems": 1 }
        }
      },
      "handoff": {
        "type": "object",
        "required": ["next_agent"],
        "properties": {
          "next_agent": { "const": "06-builder" },
          "approval_timestamp": { "type": "string", "format": "date-time" },
          "approved_until": { "type": "string", "format": "date-time" }
        }
      },
      "blockers": { "type": "array" }
    }
  },

  "build-package.json": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Build Package (Builder Agent)",
    "type": "object",
    "required": ["agent", "inputs", "outputs", "handoff", "blockers"],
    "properties": {
      "agent": { "const": "06-builder" },
      "version": { "type": "string" },
      "timestamp": { "type": "string", "format": "date-time" },
      "inputs": {
        "type": "object",
        "required": ["design_package", "github_approval"],
        "properties": {
          "design_package": { "type": "object" },
          "github_approval": { "type": "object" }
        }
      },
      "tasks": { "type": "array", "items": { "type": "string" } },
      "outputs": {
        "type": "object",
        "required": ["source_code_url", "component_status", "build_artifacts"],
        "properties": {
          "source_code_url": { "type": "string", "format": "uri" },
          "component_status": { "type": "object" },
          "build_artifacts": { "type": "array" },
          "deployment_instructions": { "type": "string" },
          "performance_metrics": { "type": "object" }
        }
      },
      "handoff": {
        "type": "object",
        "required": ["next_agent"],
        "properties": {
          "next_agent": { "const": "07-integration" },
          "ready_for_integration": { "type": "boolean" }
        }
      },
      "blockers": { "type": "array" }
    }
  },

  "launch-package.json": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Launch Package (Launch Agent)",
    "type": "object",
    "required": ["agent", "inputs", "outputs", "handoff", "blockers"],
    "properties": {
      "agent": { "const": "10-launch" },
      "version": { "type": "string" },
      "timestamp": { "type": "string", "format": "date-time" },
      "inputs": {
        "type": "object",
        "required": ["qa_sign_off", "email_campaign"],
        "properties": {
          "qa_sign_off": { "type": "object" },
          "email_campaign": { "type": "object" }
        }
      },
      "tasks": { "type": "array", "items": { "type": "string" } },
      "outputs": {
        "type": "object",
        "required": ["live_url", "seo_metadata", "og_tags", "release_notes"],
        "properties": {
          "live_url": { "type": "string", "format": "uri" },
          "seo_metadata": { "type": "object" },
          "og_tags": { "type": "object" },
          "release_notes": { "type": "string" },
          "monitoring_dashboards": { "type": "array" }
        }
      },
      "handoff": {
        "type": "object",
        "properties": {
          "status": { "const": "COMPLETE" }
        }
      },
      "blockers": { "type": "array" }
    }
  }
}
