{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Content Package",
  "type": "object",
  "required": ["agent", "outputs", "handoff", "blockers"],
  "properties": {
    "agent": { "const": "04-content" },
    "outputs": {
      "type": "object",
      "required": ["copy_inventory", "seo_optimization"],
      "properties": {
        "copy_inventory": { "type": "object" },
        "seo_optimization": { "type": "object" },
        "tone_of_voice": { "type": "string" }
      }
    },
    "handoff": {
      "type": "object",
      "required": ["next_agent"],
      "properties": {
        "next_agent": { "const": "06-builder" }
      }
    },
    "blockers": { "type": "array" }
  }
}
